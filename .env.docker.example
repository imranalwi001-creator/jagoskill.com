APP_NAME=Jagoskill
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_VERSION=2.1
APP_URL=http://localhost:8000
LOG_CHANNEL=stack
JWT_SECRET=

# Docker database service
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=jagoskill_local
DB_USERNAME=jagoskill
DB_PASSWORD=jagoskill

# Email lokal: gunakan log agar tidak mengirim email asli saat testing
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=local@jagoskill.test
MAIL_FROM_NAME="Jagoskill Local"

QUEUE_CONNECTION=sync
SESSION_DRIVER=file
CACHE_DRIVER=file

MINIO_KEY=
MINIO_SECRET=
MINIO_REGION=
MINIO_BUCKET=
MINIO_ENDPOINT=
